# Server Configuration
NODE_ENV=production
PORT=3000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/poolGame?retryWrites=true&w=majority

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=30d
BROWSER_JWT_SECRET=shared-browser-jwt-secret

# CORS
ALLOWED_ORIGINS=https://yourgame.com,https://www.yourgame.com

# ─── 0G Data Availability ────────────────────────────────────────────────────
# Login session events dispatched to the 0G DA gateway
# ZEROG_DA_GATEWAY_URL=https://da.warzonewarriors.xyz
# ZEROG_DA_API_KEY=
# ZEROG_DA_ENABLED=true   # set false to disable DA submission

# ─── 0G Compute (TEE-verified inference) ─────────────────────────────────────
# OpenAI-compatible router endpoint — get key at https://pc.0g.ai
# ZEROG_API_KEY=
# ZEROG_BASE_URL=https://router-api.0g.ai/v1
# ZEROG_MODEL=zai-org/GLM-5-FP8
# ZEROG_COMPUTE_ROUTING=latency         # latency | price | quality
# ZEROG_COMPUTE_RATE_LIMIT=20           # requests per 15 min per IP
# ZEROG_COMMENT_RATE_LIMIT=10           # leaderboard comment requests per min per IP
# ZEROG_POOL_MODEL=zai-org/GLM-5-FP8
# ZEROG_POOL_MAX_TOKENS=150
# ZEROG_POOL_TIMEOUT_MS=8000
# ZEROG_ANALYSIS_TIMEOUT_MS=20000
# ZEROG_ANTICHEAT_TIMEOUT_MS=8000

# ─── 0G EVM Chain (cross-layer session anchor) ───────────────────────────────
# Deploy PoolSessionAnchor.sol on 0G EVM then set:
#   RPC:      https://evmrpc.0g.ai   (chainId 16600)
#   Explorer: https://chainscan.0g.ai
# ZG_POOL_ANCHOR_ADDRESS=0xYourAnchorContractAddress
# ZG_PRIVATE_KEY=                     # operator wallet — never commit this
# ZG_RPC_URL=https://evmrpc.0g.ai
# ZG_CHAIN_ID=16600

# ─── EVM session contract (stats recording) ──────────────────────────────────
# BLOCKCHAIN_RPC_URL=https://evmrpc.0g.ai
# OPERATOR_PRIVATE_KEY=               # reuse ZG_PRIVATE_KEY or separate wallet
# CONTRACT_ADDRESS=0xYourSessionContractAddress

# ─── Unity WebGL / 0G Storage ────────────────────────────────────────────────
# GAME_WEBGL_CDN_BASE_URL=https://your-game.cdn.example.com
# GAME_WEBGL_0G_MANIFEST_PATH=        # default: public/zeroGpool-play/webgl-0g-manifest.json
# GAME_WEBGL_INDEXER_PROBE=true
# GAME_WEBGL_INDEXER_PROBE_TIMEOUT_MS=4500
