# Server Configuration
NODE_ENV=production
PORT=3000

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/poolGame?retryWrites=true&w=majority

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=30d
BROWSER_JWT_SECRET=shared-browser-jwt-secret

# CORS
ALLOWED_ORIGINS=https://yourgame.com,https://www.yourgame.com

# 0G DA — login session events (same Event Gateway pattern as Highway Hustle)
# ZEROG_DA_GATEWAY_URL=https://da.warzonewarriors.xyz
# ZEROG_DA_API_KEY=
# Set ZEROG_DA_ENABLED=false to skip submitting login events (default: enabled)

# EVM session contract (optional; point at 0G EVM or any chain)
# BLOCKCHAIN_RPC_URL=https://evmrpc.0g.ai
# OPERATOR_PRIVATE_KEY=
# CONTRACT_ADDRESS=

# Unity WebGL 0G manifest for the React app (GET /api/game/webgl-manifest)
# GAME_WEBGL_CDN_BASE_URL=https://your-game.cdn.example.com
# Optional: override manifest path (default: public/zeroGpool-play/webgl-0g-manifest.json)
# GAME_WEBGL_0G_MANIFEST_PATH=
# Optional: JSON-RPC probe to indexer (cluster + sample roots); cached per-RPC.
# GAME_WEBGL_INDEXER_PROBE=false
# GAME_WEBGL_INDEXER_PROBE_TIMEOUT_MS=4500
# Compact probe only: GET /api/game/storage-indexer-health (no large entries[] in body)
